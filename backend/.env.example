# =============================
# SHD Careers Backend (.env)
# =============================

APP_NAME="SHD Careers API"
APP_ENV="local"
CORS_ORIGINS="http://localhost:5173"

# SQLite path (relative ok)
DB_PATH="./data/app.db"
UPLOAD_DIR="./uploads"

# Admin notification email (optional)
ADMIN_EMAIL="careers@shd-technology.co.th"

# =============================
# Admin backend (Phase 1)
# =============================
# รหัสผ่านแอดมินชุดเดียว (เก็บฝั่ง server เท่านั้น ห้ามใส่ใน frontend)
ADMIN_PASSWORD="change-this-strong-password"
# secret สำหรับเซ็น token — สุ่มยาวๆ (เช่น `openssl rand -hex 32`)
ADMIN_JWT_SECRET="change-this-random-secret"
# อายุ token (วินาที) ค่าเริ่มต้น 8 ชั่วโมง
ADMIN_TOKEN_TTL_SEC="28800"
# อายุ signed URL สำหรับดาวน์โหลด resume (วินาที) ค่าเริ่มต้น 1 ชั่วโมง
SIGNED_URL_TTL_SEC="3600"

# SMTP (optional)
SMTP_HOST=""
SMTP_PORT="587"
SMTP_USER=""
SMTP_PASS=""
SMTP_TLS="true"
SMTP_FROM="SHD Careers <no-reply@shd-technology.co.th>"
